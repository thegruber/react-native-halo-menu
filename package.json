{
  "name": "react-native-halo-menu",
  "version": "0.1.0",
  "description": "Pinterest-style hold menu for React Native — long-press, drag, release. A radial action menu powered by Reanimated 4 and Gesture Handler, zero native code.",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./mock": "./mock.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "mock.js",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "sideEffects": false,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:check": "pnpm run build && npm pack --dry-run",
    "quality": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run format:check && pnpm run package:check",
    "prepare": "bob build",
    "prepublishOnly": "pnpm run quality"
  },
  "keywords": [
    "react-native",
    "expo",
    "radial-menu",
    "pie-menu",
    "hold-menu",
    "context-menu",
    "pinterest",
    "long-press",
    "drag-to-select",
    "action-menu",
    "reanimated",
    "gesture-handler",
    "menu",
    "ios",
    "android"
  ],
  "author": "Adrian Gruber",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thegruber/react-native-halo-menu.git"
  },
  "homepage": "https://github.com/thegruber/react-native-halo-menu#readme",
  "bugs": {
    "url": "https://github.com/thegruber/react-native-halo-menu/issues"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": ">=0.81.0",
    "react-native-gesture-handler": ">=2.16.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-worklets": "*"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.85.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.15",
    "del-cli": "^6.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^6.1.1",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.42.1",
    "react-native-gesture-handler": "2.31.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "5.7.0",
    "react-native-worklets": "0.8.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.46.4"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
